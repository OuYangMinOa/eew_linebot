# LINE bot 憑證（必填）
CHANNEL_SECRET=
CHANNEL_ACCESS_TOKEN=

# ngrok authtoken（選填：有設定才會開 ngrok tunnel）
NGROK_AUTHTOKEN=

# 開發者的 LINE user id（選填：啟動時會推送一則測試警報）
DEVELOP=

